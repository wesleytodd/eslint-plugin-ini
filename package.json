{
  "name": "@wesleytodd/eslint-plugin-ini",
  "version": "0.1.0",
  "description": "eslint plugin for processing ini files",
  "main": "index.js",
  "type": "module",
  "keywords": [
    "eslint",
    "eslint plugin",
    "ini"
  ],
  "scripts": {
    "setup": "npm install",
    "setup:ci": "npm ci",
    "test": "npm run test:eslint9 && npm run test:eslint10",
    "test:eslint9": "TEST_ESLINT_IMPORT=eslint9 mocha",
    "test:eslint10": "TEST_ESLINT_IMPORT=eslint10 mocha",
    "test:inspect": "mocha --inspect --inspect-brk",
    "test:cover": "TEST_ESLINT_IMPORT=eslint10 c8 mocha",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prerelease": "git pull --ff-only && npm run lint && npm test && npm version \"${RELEASE_AS:-patch}\" && npm login",
    "release": "npm publish --access=public --tag=\"${RELEASE_TAG:-latest}\"",
    "postrelease": "(npm logout || true) && git push --follow-tags && gh release create --draft --generate-notes \"v$(cat package.json | jq -r .version)\""
  },
  "author": "Wes Todd <wes@wesleytodd.com>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/wesleytodd/eslint-plugin-ini.git"
  },
  "engines": {
    "node": ">=20"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11",
      "onFail": "warn"
    }
  },
  "peerDependencies": {
    "eslint": "9.x || 10.x"
  },
  "dependencies": {
    "@eslint/plugin-kit": "^0.5.1"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint10": "npm:eslint@^10.4.0",
    "eslint9": "npm:eslint@^9.39.4",
    "mocha": "^11.7.5",
    "neostandard": "^0.13.0"
  }
}
